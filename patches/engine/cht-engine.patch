+/*
+ * U4 繁中化:F2 遊玩中即時切換 EGA(Ultima-IV)↔ VGA(U4-Upgrade)tileset。
+ *
+ * 約束:Boron atom(symbol)per-config(各 config 自建 boron env),故 ImageMgr
+ * 與遊戲查表必須同一個 config → 只能整個換 xu4.config(full swap)。
+ *
+ * 但兩 config 的 maps/tiles 邏輯相同(VGA 模組繼承同一份 rules),所以「換 config +
+ * screenReInit(重建 VGA imageMgr/tileset/tileanims)」後,只需把當前 location 堆疊
+ * 的每張 map 與 mapArea 的 tileset『重新指向』新 config 同 ID 的物件,保留座標。
+ * 不用 setMap(避免把新 Location 疊上舊堆疊 → 先前延遲崩潰之源)。
+ * 隊伍/存檔/座標(party、saveGame、coords)config-independent,不受影響。
+ *
+ * 雙 config 並存(不 free,避免懸空):啟動 config 歸入對應槽,另一套首次 configInit。
+ */
+bool gameToggleGraphics() {
+    // U4 繁中化:intro 標題/選單也可預覽切換主題,故只要求 imageMgr 存在;
+    // location 相關更新(map/音樂/訊息)再個別 gate 在 c->location。
+    if (! xu4.imageMgr)
+        return false;
+
+    /* U4 繁中化:F2 主題循環(可擴)。EGA → VGA → FM Towns → 循環。
+       新增主題 = 加一個 extension 模組 + 在此清單加一列。 */
+    static const struct { const char* mod; const char* label; } themes[] = {
+        { "Ultima-IV",  "圖形:EGA" },
+        { "U4-Upgrade", "圖形:VGA" },
+        { "U4-FMTowns", "圖形:FM Towns" },
+        { "U4-Amiga",   "圖形:Amiga" },
+        { "U4-MSX2",    "圖形:MSX2" },
+        { "U4-X68000",  "圖形:X68000" },
+        { "U4-SMS",     "圖形:Sega MS" },
+    };
+    const int N = (int)(sizeof(themes) / sizeof(themes[0]));
+    static Config* cache[8] = { NULL };
+    static int cur = -1;
+
+    if (cur < 0) {                              /* 首次:判斷目前主題(EGA/VGA)*/
+        cur = xu4.imageMgr->usingVGA() ? 1 : 0;
+        cache[cur] = xu4.config;
+    }
+
+    /* 迴圈找下一個「可載入」的主題:缺模組(使用者沒放該平台資產)就跳過,
+       連續多個缺失也能跳過,繞一圈都沒有就維持原狀(return false)。 */
+    int nxt = cur;
+    for (int tries = 0; tries < N - 1; ++tries) {
+        nxt = (nxt + 1) % N;
+        if (! cache[nxt]) {
+            /* 先確認模組檔存在再 configInit;否則 configInit 對缺檔會直接
+               errorFatal("Cannot find module ...") 殺掉程式(實測:遊戲中/intro
+               F2 循環到未打包的 FM Towns/MSX2/… 主題即崩潰)。 */
+            if (! configModuleExists(themes[nxt].mod))
+                continue;                       /* 缺模組 → 跳過該主題 */
+            cache[nxt] = configInit(themes[nxt].mod, xu4.settings->soundtrack);
+        }
+        if (cache[nxt]) break;                  /* 找到可用主題 */
+    }
+    if (nxt == cur || ! cache[nxt]) return false;   /* 沒有其他可用主題 */
+
+    cur = nxt;
+    xu4.config = cache[cur];
+    screenReInit();
+
