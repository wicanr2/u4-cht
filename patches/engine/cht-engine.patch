+/* U4 繁中化 self-test(env U4CHT_SELFTEST):headless 驗證
+ * 資產載入→真實 chtLookup→CJK glyph blit→上傳 全鏈路。每幀覆寫到文字區。 */
+static void chtSelfTest() {
+    if (! getenv("U4CHT_SELFTEST")) return;
+    static const char* keys[] = {
+        "a charming bard.",
+        "Magincia was\ndestroyed by its\npride.",
+    };
+    int line = 0;
+    for (int ki = 0; ki < 2; ++ki) {
+        const char* en = keys[ki];
+        const char* zh = chtLookup(en, (int) strlen(en));
+        if (! zh) { line += 1; continue; }
+        int col = 0;
+        const unsigned char* p = (const unsigned char*) zh;
+        while (*p) {
+            unsigned char b = *p;
+            if (b == '\n') { col = 0; line += 1; ++p; continue; }
+            uint32_t cp; int n;
+            if (b < 0x80)             { cp = b;        n = 1; }
+            else if ((b >> 5) == 0x6) { cp = b & 0x1F; n = 2; }
+            else if ((b >> 4) == 0xE) { cp = b & 0x0F; n = 3; }
+            else if ((b >> 3) == 0x1E){ cp = b & 0x07; n = 4; }
+            else { ++p; continue; }
+            for (int k = 1; k < n; ++k) { if ((p[k] & 0xC0) != 0x80) { n = k; break; }
+                cp = (cp << 6) | (p[k] & 0x3F); }
+            p += n;
+            if (cp < 0x80) { screenShowChar((int) cp, TEXT_AREA_X + col, TEXT_AREA_Y + line); col++; }
+            else { if (col + 1 > TEXT_AREA_W) { col = 0; line += 1; }
+                cjkBlit(cp, col, line); col += 1; }
+        }
+        line += 1;
+    }
+    XU4_SCREEN->uploadScreen = 1;
+}
