+/* U4 繁中化:buffer 是否含 UTF-8 多位元組(CJK)。 */
+static bool chtHasCJK(const char* s, int len) {
+    for (int i = 0; i < len; ++i)
+        if ((unsigned char) s[i] >= 0x80) return true;
+    return false;
+}
+
+/* U4 繁中化:把一個 CJK glyph(16×16 灰階 alpha)blit 到絕對像素 (px,py)。 */
+static void cjkBlitPx(uint32_t cp, int px, int py) {
+    const uint8_t* g = chtGlyph(cp);
+    int dim = chtGlyphDim();
+    Image* screen = xu4.screenImage;
+    if (! g) {
+        screen->fillRect(px, py, dim, dim, 60, 60, 60);   // 缺字:灰框
+        return;
+    }
+    for (int y = 0; y < dim; ++y)
+        for (int x = 0; x < dim; ++x) {
+            int a = g[y * dim + x];   // 灰階 alpha:白字混黑底(二值 atlas 亦相容)
+            screen->putPixel(px + x, py + y, a, a, a, 255);
+        }
+}
+
+/* 文字區 cell(col,line)→ 絕對像素 blit。 */
+static void cjkBlit(uint32_t cp, int col, int line) {
+    cjkBlitPx(cp, (TEXT_AREA_X + col) * CHAR_WIDTH, (TEXT_AREA_Y + line) * CHAR_HEIGHT);
+}
+
+/* U4 繁中化:把已翻譯 UTF-8 字串渲染到絕對 cell(cellX,cellY)起(單行,夾雜 ASCII)。
+ * 供 screenTextAt(HUD)使用。 */
+static void screenDrawCJKAt(const char* s, int cellX, int cellY) {
+    const unsigned char* p = (const unsigned char*) s;
+    int col = 0;
+    while (*p) {
+        unsigned char b = *p;
+        uint32_t cp; int n;
+        if (b < 0x80)            { cp = b;        n = 1; }
+        else if ((b >> 5) == 0x6){ cp = b & 0x1F; n = 2; }
+        else if ((b >> 4) == 0xE){ cp = b & 0x0F; n = 3; }
+        else if ((b >> 3) == 0x1E){cp = b & 0x07; n = 4; }
+        else { ++p; continue; }
+        for (int k = 1; k < n; ++k) {
+            if ((p[k] & 0xC0) != 0x80) { n = k; break; }
+            cp = (cp << 6) | (p[k] & 0x3F);
+        }
+        p += n;
+        if (cp < 0x80) { screenShowChar((int) cp, cellX + col, cellY); col += 1; }
+        else { cjkBlitPx(cp, (cellX + col) * CHAR_WIDTH, cellY * CHAR_HEIGHT); col += 1; }
+    }
+}
+
+/* U4 繁中化:把已翻譯的 UTF-8 中文字串渲染到文字區(CJK-aware,行距 2)。 */
+static void screenMessageCJK(const char* s) {
+    const int colCount = TEXT_AREA_W;
+    const unsigned char* p = (const unsigned char*) s;
+    if (c->line >= TEXT_AREA_H) { c->line = TEXT_AREA_H - 1; screenScrollMessageArea(); }
+    while (*p) {
+        unsigned char b = *p;
+        if (b == '\n') {
+            c->col = 0; c->line += 1;
+            while (c->line >= TEXT_AREA_H) { c->line--; screenScrollMessageArea(); }
+            ++p; continue;
+        }
+        uint32_t cp; int n;
+        if (b < 0x80)            { cp = b;        n = 1; }
+        else if ((b >> 5) == 0x6){ cp = b & 0x1F; n = 2; }
+        else if ((b >> 4) == 0xE){ cp = b & 0x0F; n = 3; }
+        else if ((b >> 3) == 0x1E){cp = b & 0x07; n = 4; }
+        else { ++p; continue; }
+        for (int k = 1; k < n; ++k) {
+            if ((p[k] & 0xC0) != 0x80) { n = k; break; }
+            cp = (cp << 6) | (p[k] & 0x3F);
+        }
+        p += n;
+        if (cp < 0x80) {                          // 夾雜 ASCII
+            if (c->col >= colCount) { c->col = 0; c->line += 1;
+                while (c->line >= TEXT_AREA_H) { c->line--; screenScrollMessageArea(); } }
+            screenShowChar((int) cp, TEXT_AREA_X + c->col, TEXT_AREA_Y + c->line);
+            c->col++;
+        } else {                                  // CJK 全形,佔 2 欄
+            if (c->col + 1 > colCount) { c->col = 0; c->line += 1;
+                while (c->line >= TEXT_AREA_H) { c->line--; screenScrollMessageArea(); } }
+            cjkBlit(cp, c->col, c->line);
+            c->col += 1;
+        }
+    }
+    screenSetCursorPos(TEXT_AREA_X + c->col, TEXT_AREA_Y + c->line);
+}
